{
  "buildCommand": "npm ci && npm ci --prefix server && npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/index.js": { "maxDuration": 30, "includeFiles": "server/src/**" },
    "api/[...path].js": { "maxDuration": 30, "includeFiles": "server/src/**" },
    "api/auth/**/*.js": { "maxDuration": 30, "includeFiles": "server/src/**" }
  },
  "rewrites": [
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
