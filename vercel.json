{
  "buildCommand": "npm ci && npm ci --prefix server && npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/**/*.js": { "maxDuration": 30, "includeFiles": "server/**" }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api?path=:path*" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
