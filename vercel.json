{
  "buildCommand": "npm ci && npm ci --prefix server && npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "includeFiles": "server/src/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api?path=:path*" },
    { "source": "/api", "destination": "/api" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
