# Tezca SPA trong thư mục con (vd. public_html/tezca/)
# Cần bật mod_rewrite. API /ws phải proxy ở cấp Apache/Nginx (xem apache-snippet.conf).

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /tezca/
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /tezca/index.html [L]
</IfModule>
