<?xml version="1.0" encoding="UTF-8"?>
<!--
  Tezca — IIS (URL Rewrite + ARR reverse proxy)
  Yêu cầu: Application Request Routing (ARR), URL Rewrite, WebSocket Protocol.
  Static SPA: copy dist/ vào thư mục site IIS (cùng cấp file web.config này).
  API Node: chạy nội bộ 127.0.0.1:3001 (NODE_ENV=production, JWT_SECRET=...).
-->
<configuration>
  <system.webServer>
    <directoryBrowse enabled="false" />

    <security>
      <requestFiltering>
        <!-- 512 KB — khớp express.json limit -->
        <requestLimits maxAllowedContentLength="524288" />
        <hiddenSegments>
          <add segment=".env" />
          <add segment="node_modules" />
        </hiddenSegments>
      </requestFiltering>
    </security>

    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="DENY" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        <remove name="X-Powered-By" />
      </customHeaders>
    </httpProtocol>

    <rewrite>
      <rules>
        <rule name="Tezca API reverse proxy" stopProcessing="true">
          <match url="^api/(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:3001/api/{R:1}" />
        </rule>
        <rule name="Tezca WebSocket reverse proxy" stopProcessing="true">
          <match url="^ws(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:3001/ws{R:1}" />
        </rule>
        <rule name="Tezca SPA fallback" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
