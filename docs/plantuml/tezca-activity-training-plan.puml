@startuml Tezca_Training_Plan_Flow
skinparam shadowing false
skinparam roundcorner 12
skinparam linetype ortho
skinparam defaultFontName "Segoe UI", Arial, sans-serif
skinparam defaultFontSize 12
skinparam swimlane {
  BorderColor #B0BEC5
  TitleFontColor #263238
  TitleFontStyle bold
}
skinparam activity {
  BackgroundColor #E3F2FD
  BorderColor #1976D2
  FontColor #263238
}
skinparam activityDiamond {
  BackgroundColor #FFF9C4
  BorderColor #F9A825
  FontColor #263238
}
skinparam activityStart {
  BackgroundColor #43A047
  BorderColor #2E7D32
}
skinparam activityEnd {
  BackgroundColor #FFFFFF
  BorderColor #263238
}

|Khách hàng (Client)|
start
:Nhập thông số thể trạng và bệnh lý nền;
:Click 'Yêu cầu tạo lộ trình mới';

|Hệ thống Tezca (API & AI)|
:Đóng gói dữ liệu Prompt;
:Gửi HTTPS Request tới Google Gemini API;
:Parse JSON & Lưu lộ trình (Trạng thái: Pending);
:Gửi Notification yêu cầu duyệt giáo án;

|Chuyên gia (Doctor Desk)|
:Nhận thông báo & Truy cập màn hình quản lý;
:Xem chi tiết giáo án do AI đề xuất;

if (Cần điều chỉnh chuyên môn?) then (Có)
  :Sửa đổi bài tập, sets, reps;
  :Thêm ghi chú y khoa (Expert Note);
else (Không)
endif

:Click 'Phê duyệt lộ trình';

|Hệ thống Tezca (API & AI)|
:Cập nhật trạng thái 'Approved' và lưu dấu vết Audit Log;
:Emit WebSocket Event đồng bộ xuống Mobile App;

|Khách hàng (Client)|
:Nhận thông báo giáo án mới;

fork
  :Thực hiện tập luyện & Đánh dấu hoàn thành;
fork again
  :Đo lường & Cập nhật BMI;
fork again
  :Ghi nhận nhật ký cảm xúc;
end fork

|Hệ thống Tezca (API & AI)|
:Lưu trữ dữ liệu (Upsert) vào SQLite;
:Tổng hợp & Tính toán chỉ số thống kê tuần;

|Chuyên gia (Doctor Desk)|
:Truy cập Dashboard Báo cáo tuần;
:Đánh giá tiến độ và đưa ra chẩn đoán;
stop

@enduml
