@startuml Tezca_Domain_Model
top to bottom direction

skinparam shadowing false
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam dpi 200
skinparam defaultFontName "Segoe UI", Arial, sans-serif
skinparam defaultFontSize 15
skinparam nodesep 50
skinparam ranksep 60

' Cấu hình chung
skinparam class {
    BackgroundColor White
    BorderColor #042e5a
    ArrowColor DimGray
    HeaderBackgroundColor #042e5a
    HeaderFontColor White
    FontSize 15
}
skinparam package {
    BorderColor #042e5a
    FontColor #042e5a
    FontStyle bold
    FontSize 16
}

title Mô hình lớp miền (theo gói) — Tezca Health

package "1. Quản lý Người dùng" {
    class User {
        +id: string [PK]
        +email: string
        +role: enum
    }
    class Admin
    class Expert
    class Patient
    User <|-- Admin
    User <|-- Expert
    User <|-- Patient
}

package "2. Nghiệp vụ Chính" {
    class Assignment {
        +expert_id, patient_id [PK]
    }
    class TrainingPlan {
        +patient_id [PK]
        +status: enum
    }
    Expert "1" -- "0..*" Assignment
    Patient "1" -- "0..*" Assignment
    Patient "1" -- "0..1" TrainingPlan
}

package "3. Dữ liệu & Nhật ký" {
    class BmiEntry {
        +id [PK]
        +user_id [FK]
    }
    class MoodEntry {
        +id [PK]
        +user_id [FK]
    }
    class BotMessage {
        +id [PK]
        +user_id [FK]
    }
    class LiveMessage {
        +id [PK]
        +patient_id [FK]
    }
    class AuditLog {
        +id [PK]
        +actor_id [FK]
    }

    Patient "1" *-- "0..*" BmiEntry
    Patient "1" *-- "0..*" MoodEntry
    Patient "1" *-- "0..*" BotMessage
}

package "4. Cộng đồng (Mới)" {
    class Post {
        +id [PK]
        +user_id [FK]
    }
    class Comment {
        +id [PK]
        +post_id [FK]
    }

    User "1" -- "0..*" Post
    Post "1" *-- "0..*" Comment
    User "1" -- "0..*" Comment
}

' Kết nối Log
Admin "1" -- "0..*" AuditLog
Expert "1" -- "0..*" AuditLog

@enduml
