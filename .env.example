# Sao chép thành .env (không commit file .env)

# Google Gemini — chỉ dùng trên server
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-key
GOOGLE_GENERATIVE_AI_MODEL=gemini-2.5-flash

# Đăng nhập Google (OAuth 2.0) — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI (bắt buộc khớp chính xác):
#   Dev:  http://127.0.0.1:3001/api/auth/google/callback  (hoặc cổng API bạn dùng)
#   Prod: https://your-domain.com/api/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
# Tùy chọn — nếu API và frontend khác origin:
# GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.com/api/auth/google/callback
# TEZCA_APP_URL=https://your-domain.com

# Giới hạn gọi AI (tùy chọn)
# AI_RATE_LIMIT_CHAT=30
# AI_RATE_LIMIT_PLAN=8

# Giới hạn auth (tùy chọn)
# AUTH_RATE_LIMIT_LOGIN=20
# AUTH_RATE_LIMIT_RESET=10
# NEWSLETTER_RATE_LIMIT=6

# Production: bắt buộc đổi secret mạnh (Vercel Dashboard → Environment Variables)
JWT_SECRET=tezca-change-me-in-production

# Production Vercel — https://tezca-hope.vercel.app
# TEZCA_APP_URL=https://tezca-hope.vercel.app
# NODE_ENV=production

# Seed 100 KH demo + 4 CG + dữ liệu công việc khi DB trống/thiếu (mặc định bật trên Vercel)
# TEZCA_SEED_DEMO=1
# TEZCA_SEED_DEMO=0

# Production CORS: domain frontend, phân tách bằng dấu phẩy
# TEZCA_CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Quên mật khẩu — URL frontend trong email (production)
# TEZCA_APP_URL=https://your-domain.com

# Gửi email qua Resend (https://resend.com) — tùy chọn; dev in link ra console API
# RESEND_API_KEY=re_...
# TEZCA_MAIL_FROM=Tezca <noreply@your-domain.com>

# Chỉ dev: trả resetUrl trong JSON (production dùng email)
# TEZCA_EXPOSE_RESET_LINK=1
