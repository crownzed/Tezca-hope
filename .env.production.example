# Copy thành .env.production rồi build: npm run build
# Hoặc đặt biến khi build (PowerShell):
#   $env:VITE_BASE_PATH="/tezca/"; npm run build

# Đường dẫn trên website có sẵn (bắt buộc có / đầu và cuối nếu là thư mục con)
VITE_BASE_PATH=/tezca/

# Chỉ cần nếu API ở domain/port khác (mặc định để trống = cùng domain, proxy /api)
# VITE_API_URL=https://your-domain.com
